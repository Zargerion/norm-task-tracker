NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/norm_task_tracker?schema=public
JWT_SECRET=change_me_very_long_secret_at_least_32_chars
JWT_EXPIRES_IN=1h
MAGIC_TOKEN_EXPIRES_IN=15m
# Для `yarn dev` достаточно localhost:3000; для Docker (`infra/docker-compose.dev.yml`) фронт на :3100 — см. CORS ниже
CORS_ORIGIN=http://localhost:3000,http://localhost:3100
FRONTEND_URL=http://localhost:3000
BOT_TOKEN=your_token_from_botfather
BOT_WEBHOOK_SECRET=change_me_webhook_secret
BOT_USERNAME=your_bot_username
BODY_PARSER_LIMIT=20mb
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# prisma db seed (./scripts/seed.sh) — только через ENV, не храните реальные значения в репозитории
SEED_SUPER_ADMIN_LOGIN=superadmin_login
SEED_SUPER_ADMIN_PASSWORD=change_me_strong_password
SEED_SUPER_ADMIN_TELEGRAM_ID=your_numeric_telegram_id
# SEED_SUPER_ADMIN_FIRST_NAME=Имя
# SEED_SUPER_ADMIN_LAST_NAME=Фамилия
