generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SpaceRole {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum TaskStatus {
  CREATED
  ACCEPTED
  COMPLETED
  APPROVED
}

enum MaterialType {
  MARKDOWN
  HTML
}

model User {
  id            String   @id @default(uuid())
  firstName     String
  lastName      String
  login         String   @unique
  passwordHash  String
  jobTitle      String?
  favoriteColor String?
  description   String?
  phone         String?
  email         String?  @unique
  avatarUrl     String?
  telegramId    String?  @unique
  isSuperAdmin  Boolean  @default(false)
  isApproved    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pendingCode      PendingCode?
  magicTokens      MagicToken[]
  spaceUsers       SpaceUser[]
  projectMembers   ProjectMember[]
  createdTasks     Task[]           @relation("TaskCreator")
  taskAssignees    TaskAssignee[]
  taskAdditions    TaskAddition[]
  materialAccesses MaterialAccess[]
  createdMaterials Material[]
}

model PendingCode {
  id        String   @id @default(uuid())
  userId    String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MagicToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model Space {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  spaceUsers SpaceUser[]
  projects   Project[]
  tasks      Task[]
  materials  Material[]
}

model SpaceUser {
  id        String    @id @default(uuid())
  userId    String
  spaceId   String
  role      SpaceRole @default(EMPLOYEE)
  createdAt DateTime  @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([userId, spaceId])
}

model Project {
  id          String   @id @default(uuid())
  spaceId     String
  name        String
  description String?
  color       String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  space      Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  milestones Milestone[]
  members    ProjectMember[]
  tasks      Task[]
}

model Milestone {
  id          String   @id @default(uuid())
  projectId   String
  title       String
  description String?
  date        DateTime
  notified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectMember {
  id                   String   @id @default(uuid())
  projectId            String
  userId               String
  notificationsEnabled Boolean  @default(true)
  createdAt            DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Task {
  id             String     @id @default(uuid())
  projectId      String
  spaceId        String
  title          String
  description    String?
  estimatedHours Float?
  status         TaskStatus @default(CREATED)
  position       Int        @default(0)
  createdById    String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  space       Space            @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  createdBy   User             @relation("TaskCreator", fields: [createdById], references: [id])
  assignees   TaskAssignee[]
  timeRecords TaskTimeRecord[]
  additions   TaskAddition[]
  attachments TaskAttachment[]
}

model TaskAssignee {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model TaskTimeRecord {
  id          String    @id @default(uuid())
  taskId      String
  acceptedAt  DateTime
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model TaskAddition {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TaskAttachment {
  id        String   @id @default(uuid())
  taskId    String
  filename  String
  url       String
  mimeType  String
  isImage   Boolean  @default(false)
  size      Int
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Material {
  id          String       @id @default(uuid())
  spaceId     String
  title       String
  content     String?
  type        MaterialType @default(MARKDOWN)
  htmlUrl     String?
  isPublic    Boolean      @default(false)
  isSpaceWide Boolean      @default(false)
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  space       Space               @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  createdBy   User                @relation(fields: [createdById], references: [id])
  attachments MaterialAttachment[]
  accesses    MaterialAccess[]
}

model MaterialAttachment {
  id         String   @id @default(uuid())
  materialId String
  filename   String
  url        String
  mimeType   String
  size       Int
  createdAt  DateTime @default(now())

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
}

model MaterialAccess {
  id         String   @id @default(uuid())
  materialId String
  userId     String
  createdAt  DateTime @default(now())

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([materialId, userId])
}
